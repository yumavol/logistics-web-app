generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ItemStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model Item {
  id          String     @id @default(cuid())
  name        String
  description String?
  status      ItemStatus @default(DRAFT)
  priority    Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}
